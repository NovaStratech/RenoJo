# ----- App -----
APP_URL=http://localhost:3000
# Used to sign client magic links and other internal tokens
TOKEN_SECRET=replace-with-32+-bytes-random-base64

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection string for Drizzle (use the "Connection pooler" / "Transaction" mode URL)
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# ----- Postmark -----
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=devis@renojo.example
POSTMARK_REPLY_DOMAIN=reply.renojo.example
POSTMARK_INBOUND_WEBHOOK_TOKEN=replace-with-shared-secret

# ----- OpenAI -----
OPENAI_API_KEY=
OPENAI_MODEL_TEXT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o
